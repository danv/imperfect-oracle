{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "imperfect-oracle",
  "agent": {
    "imperfect-oracle": {
      "description": "PF2e campaign ideas",
      "mode": "all",
      "prompt": "{file:agents/imperfect-oracle.md}",
      "color": "success",
    }
  },
  "mcp": {
    "rag-mcp-pf2e": {
      "type": "local",
      "command": [ 
        "/opt/homebrew/bin/uv",
        "--directory", "/Users/dan/projects/rag-mcp",
        "run", 
        "--env-file", "/Users/dan/projects/imperfect-oracle/rag-mcp.env", 
        "rag-mcp" 
      ]
    }
  },
  "permission": {
    "external_directory": {
      "/Users/dan/Dropbox/notes/personal/pf2e/the_imperfection/**": "allow"
    },
    "skill": {
      "rules-search": "allow"
    }
  },
  "experimental": {
    "mcp_timeout": 600000
  }
}